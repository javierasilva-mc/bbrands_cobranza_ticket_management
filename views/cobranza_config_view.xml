<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cobranza_config_form" model="ir.ui.view">
        <field name="name">cobranza.config.form</field>
        <field name="model">cobranza.config</field>
        <field name="arch" type="xml">
            <form string="Configuración de Cobranza">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre de la configuración"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="secuencia"/>
                            <field name="es_default"/>
                            <field name="esta_activo" string="Activo"/>
                        </group>
                    </group>

                    <separator string="Condiciones"/>
                    <p class="text-muted">
                        Esta configuración aplica cuando el cliente y documento coincidan
                        con las condiciones configuradas. Los campos vacíos aplican a cualquier valor.
                    </p>
                    <group>
                        <group>
                            <field name="business_unit_ids" widget="many2many_tags"/>
                            <field name="payment_term_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="document_type_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group >
                        <group string="Rango de documentos pendientes">
                            <field name="min_documentos" string="Mínimo"/>
                            <field name="max_documentos" string="Máximo"/>
                        </group>
                    </group>

                    <separator string="Configuración general"/>
                    <group>
                        <group string="Parámetros operacionales">
                            <field name="dias_vencimiento"/>
                            <field name="team_id"/>
                            <field name="ejecutivo_default_id"/>
                            <field name="incluir_in_payment"/>
                        </group>
                        <group string="Clasificación del ticket">
                            <field name="ticket_type_id"/>
                            <field name="category_id"/>
                            <field name="subcategory_id"/>
                            <field name="subcategory_template_id"/>
                        </group>
                        <group string="Stages">
                            <field name="stage_cerrado_id"/>
                            <field name="stage_in_progress_id"/>
                            <field name="stage_tarea_completada_id"/>
                        </group>
                    </group>

                    <separator string="Tareas iniciales"/>
                    <field name="tarea_ids">
                        <list editable="bottom">
                            <field name="secuencia" widget="handle"/>
                            <field name="task_template_id"/>
                            <field name="es_tarea_acuerdo"/>
                        </list>
                    </field>

                    <separator string="Reglas de seguimiento"/>
                    <field name="regla_ids">
                        <list open_form_view="true">
                            <field name="secuencia" widget="handle"/>
                            <field name="tarea_disparadora_id"/>
                            <field name="condicion"/>
                            <field name="tarea_ids" widget="many2many_tags"
                                   string="Tareas a crear"/>
                        </list>
                        <form string="Regla de seguimiento">
                            <group>
                                <field name="secuencia"/>
                                <field name="tarea_disparadora_id"/>
                                <field name="condicion"/>
                                <field name="dias_condicion"
                                       invisible="condicion != 'dias_ultima_tarea'"/>
                                <field name="requiere_tarea_completada"/>
                            </group>
                            <separator string="Tareas a crear"/>
                            <field name="tarea_ids">
                                <list editable="bottom">
                                    <field name="secuencia" widget="handle"/>
                                    <field name="task_template_id" string="Plantilla de tarea"/>
                                </list>
                            </field>
                        </form>
                    </field>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cobranza_config_list" model="ir.ui.view">
        <field name="name">cobranza.config.list</field>
        <field name="model">cobranza.config</field>
        <field name="arch" type="xml">
            <list string="Configuraciones de Cobranza" default_order="secuencia">
                <field name="secuencia" widget="handle"/>
                <field name="name"/>
                <field name="business_unit_ids" widget="many2many_tags"/>
                <field name="document_type_ids" widget="many2many_tags"/>
                <field name="team_id"/>
                <field name="es_default"/>
                <field name="esta_activo" string="Activo"/>
            </list>
        </field>
    </record>

    <record id="action_cobranza_config" model="ir.actions.server">
        <field name="name">Configuración de Cobranza</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">action = env['cobranza.config'].action_open_config()</field>
    </record>

    <record id="menu_cobranza_config_item" model="ir.ui.menu">
        <field name="name">Configuración de Cobranza</field>
        <field name="parent_id" ref="helpdesk.helpdesk_menu_config"/>
        <field name="action" ref="action_cobranza_config"/>
        <field name="sequence">99</field>
    </record>

</odoo>